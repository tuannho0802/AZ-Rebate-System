generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  MIB
  IB
}

enum AssetCategory {
  FOREX
  METAL
  ENERGY
  COMMODITY
  INDEX
  SHARES
  CRYPTO
  OTHER
}

enum PayoutSessionStatus {
  DRAFT
  LOCKED
  COMPLETED
}

// Admin nằm ngoài cây phân cấp hoa hồng — tách bảng riêng để tránh
// vô tình bị cuốn vào Recursive CTE / rule validate cha-con.
model AdminAccount {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdAssets    Asset[]
  createdTemplates Template[]
  createdUsers     User[]         @relation("AdminCreatedUser")
  payoutSessions   PayoutSession[]
  auditLogs        AuditLog[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String?
  role         Role
  isActive     Boolean  @default(true)

  parentId     String?
  parent       User?    @relation("UserHierarchy", fields: [parentId], references: [id])
  children     User[]   @relation("UserHierarchy")

  createdByAdminId String?
  createdByAdmin   AdminAccount? @relation("AdminCreatedUser", fields: [createdByAdminId], references: [id])

  configs        UserCommissionConfig[]
  ledgerEntries  CommissionLedger[]
  sourcedSessions PayoutSession[]      @relation("PayoutSourceUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([role])
  // MIB phải có parentId null; IB phải có parentId khác null.
  // Ràng buộc này KHÔNG thể diễn đạt bằng Prisma thuần, phải thêm CHECK constraint
  // qua raw SQL migration.
}

model Asset {
  id       String        @id @default(uuid())
  code     String        @unique
  name     String
  category AssetCategory @default(OTHER)
  isActive Boolean       @default(true)

  createdByAdminId String?
  createdByAdmin   AdminAccount? @relation(fields: [createdByAdminId], references: [id])

  templateItems TemplateItem[]
  configs       UserCommissionConfig[]
  ledgerEntries CommissionLedger[]
  payoutSessions PayoutSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  createdByAdminId String?
  createdByAdmin   AdminAccount? @relation(fields: [createdByAdminId], references: [id])

  items TemplateItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TemplateItem {
  id         String  @id @default(uuid())
  templateId String
  assetId    String

  rebateUnit Decimal @db.Decimal(12, 4) @default(0)
  markupPips Decimal @db.Decimal(12, 4) @default(0)

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([templateId, assetId])
}

model UserCommissionConfig {
  id           String  @id @default(uuid())
  userId       String
  assetId      String

  rebateUnit   Decimal @db.Decimal(12, 4) @default(0)
  markupPips   Decimal @db.Decimal(12, 4) @default(0)
  transferUnit Decimal @db.Decimal(12, 4) @default(0) // = rebateUnit + markupPips, CHECK ở SQL

  version      Int     @default(1) // optimistic locking, tăng mỗi lần update

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, assetId])
  @@index([userId])
  @@index([assetId])
}

model PayoutSession {
  id           String              @id @default(uuid())
  name         String
  note         String?
  baseVolume   Decimal             @db.Decimal(18, 4)
  status       PayoutSessionStatus @default(DRAFT)

  sourceUserId String
  sourceUser   User  @relation("PayoutSourceUser", fields: [sourceUserId], references: [id])

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  createdByAdminId String?
  createdByAdmin   AdminAccount? @relation(fields: [createdByAdminId], references: [id])

  ledgerEntries CommissionLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceUserId])
  @@index([status])
}

model CommissionLedger {
  id              String  @id @default(uuid())
  payoutSessionId String
  beneficiaryId   String
  assetId         String

  netRebate       Decimal @db.Decimal(12, 4)
  netMarkup       Decimal @db.Decimal(12, 4)
  netTransferUnit Decimal @db.Decimal(12, 4)
  calculatedValue Decimal @db.Decimal(18, 4)

  session     PayoutSession @relation(fields: [payoutSessionId], references: [id], onDelete: Cascade)
  beneficiary User          @relation(fields: [beneficiaryId], references: [id])
  asset       Asset         @relation(fields: [assetId], references: [id])

  createdAt DateTime @default(now())

  @@index([beneficiaryId])
  @@index([payoutSessionId])
  @@unique([payoutSessionId, beneficiaryId]) // 1 beneficiary chỉ 1 dòng ledger / session
}

model AuditLog {
  id           String   @id @default(uuid())
  actorAdminId String?
  actorUserId  String?
  action       String   // vd: "UPDATE_COMMISSION_CONFIG", "DEACTIVATE_USER"
  entityType   String   // vd: "UserCommissionConfig"
  entityId     String
  beforeData   Json?
  afterData    Json?
  createdAt    DateTime @default(now())

  actorAdmin AdminAccount? @relation(fields: [actorAdminId], references: [id])

  @@index([entityType, entityId])
}
